# Normalizar saltos de línea a LF en el repositorio
* text=auto eol=lf

# Forzar LF para código fuente
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.css   text eol=lf
*.prisma text eol=lf
*.env*  text eol=lf

# Binarios
*.png   binary
*.jpg   binary
*.pdf   binary
