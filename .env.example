# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://workshop:workshop@localhost:5432/workshop_dev"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-64"
JWT_ACCESS_EXPIRES="8h"
JWT_REFRESH_EXPIRES="7d"

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── AWS S3 (Informes Técnicos) ──────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="workshop-manager-it-files"
S3_PRESIGNED_URL_EXPIRES=600

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
